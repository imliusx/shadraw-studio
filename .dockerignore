# Root-level .dockerignore for the monorepo build context.
# The api image uses `context: ..` from deploy/ (i.e. repo root).
# The Dockerfile only COPYs:
#   - web/ (frontend source for stage 1)
#   - go.mod, go.sum, cmd, internal, migrations (Go source for stage 2)
# Everything else can be excluded.

# ---- VCS / OS / IDE ----
.git
.gitignore
.DS_Store
.vscode
.idea

# ---- Trellis / Claude / AI tooling (not for image) ----
.trellis
.claude
.agents
AGENTS.md
CLAUDE.md
PROJECT.md
skills-lock.json
.mcp.json

# ---- Top-level files / dirs not needed inside the image ----
README.md
deploy/
docs/
Makefile
.golangci.yml
.github/
docker-compose.yml
Dockerfile
.dockerignore
.env
.env.*
!.env.example
!.env.prod.example

# ---- Backend local artifacts (Go module at repo root) ----
data/
pgdata/
minio-data/
.cache/
.gocache/
tmp/
bin/
*.test
*.out

# Embedded dist is written by the frontend-builder stage; never ship the
# (potentially stale) host copy into the build context.
internal/web/dist/

# ---- Frontend local artifacts (web/) ----
web/node_modules
web/.next
web/dist
web/build
web/out
web/coverage
web/.env
web/.env.*
web/*.log
web/README.md
web/Dockerfile
web/.dockerignore
web/.gitignore
