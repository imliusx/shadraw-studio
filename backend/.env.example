# shadraw backend env (copy to .env, fill in real values)

# Server
PORT=8080
LOG_LEVEL=info

# Database
DB_DSN=postgres://shadraw:shadraw@localhost:5432/shadraw?sslmode=disable

# Auth
# 32+ char random string for signing JWTs
JWT_SECRET=
# Email of the bootstrap admin account. Required.
ADMIN_EMAIL=

# Encryption
# 32 bytes base64-encoded (used by AES-GCM for future apiKey encryption)
MASTER_KEY=

# CORS - comma separated allowed origins for browser fetches
CORS_ORIGINS=http://localhost:3000

# Storage
BLOB_DRIVER=s3
DATA_DIR=./data

# S3 / MinIO storage (used when BLOB_DRIVER=s3)
# Use http://localhost:9000 when running the API directly on the host.
S3_ENDPOINT=http://minio:9000
S3_REGION=us-east-1
S3_BUCKET=shadraw
S3_ACCESS_KEY_ID=shadraw
S3_SECRET_ACCESS_KEY=shadrawsecret
S3_USE_PATH_STYLE=true
