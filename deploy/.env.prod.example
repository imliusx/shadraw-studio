# =========================================================
# shadraw production env. Copy to `.env` and fill in values.
# Never commit .env to git.
# =========================================================

APP_ENV=production

# Public site URL — used only as a reference for the nginx server_name on
# the host. The frontend uses relative paths (same-origin) and the backend
# no longer reads CORS_ORIGINS, so no service consumes this value at runtime.
SITE_URL=https://your-domain.com

# --- Database -------------------------------------------------
POSTGRES_USER=shadraw
# Generate: openssl rand -base64 24
POSTGRES_PASSWORD=CHANGE_ME
POSTGRES_DB=shadraw

# DB_DSN: 必须和上面 POSTGRES_USER/PASSWORD/DB 匹配。
# binary + systemd 模式固定用 localhost (docker-compose.deps.yml 把 :5432 暴露到 loopback)。
DB_DSN=postgres://shadraw:CHANGE_ME@localhost:5432/shadraw?sslmode=disable

# --- Auth & encryption ---------------------------------------
# 32+ char random string. Generate: openssl rand -base64 48
JWT_SECRET=
# Bootstrap admin account email (first /api/v1/auth/register that matches
# this becomes the admin). Required.
ADMIN_EMAIL=admin@example.com
# 32 bytes base64. Generate: openssl rand -base64 32
MASTER_KEY=

# --- MinIO / S3 -----------------------------------------------
S3_BUCKET=shadraw
S3_ACCESS_KEY_ID=shadraw
# Generate: openssl rand -base64 24
S3_SECRET_ACCESS_KEY=CHANGE_ME
# binary + systemd 模式固定用 localhost (docker-compose.deps.yml 把 :9000 暴露到 loopback)
S3_ENDPOINT=http://localhost:9000
S3_REGION=us-east-1
S3_USE_PATH_STYLE=true
BLOB_DRIVER=s3
